.tab-btn.active{background:var(--teal);border-color:var(--teal);color:var(--navy);font-weight:500;}
.prod-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(285px,1fr));gap:20px;}
.pcard{background:var(--card);border:1px solid var(--border);border-radius:17px;padding:26px 22px;position:relative;overflow:hidden;transition:transform .35s,border-color .35s;display:none;}
