.ctxt{display:flex;flex-direction:column;gap:2px;}
.ctxt .clbl{font-size:.66rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase;}
.ctxt a,.ctxt p{font-size:.86rem;color:var(--white);text-decoration:none;transition:color .3s;line-height:1.55;}
