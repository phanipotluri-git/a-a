header{position:fixed;top:0;left:0;right:0;z-index:900;padding:13px 5%;display:flex;justify-content:space-between;align-items:center;transition:background .4s,border-color .4s;border-bottom:1px solid transparent;}
header.scrolled{background:rgba(6,13,31,.9);backdrop-filter:blur(18px);border-color:var(--border);}
.logo-link{display:flex;align-items:center;gap:11px;text-decoration:none;}
.logo-svg{width:50px;height:50px;flex-shrink:0;}
.logo-text .l1{font-family:'Playfair Display',serif;font-size:1.12rem;font-weight:700;color:var(--white);letter-spacing:.03em;}
.logo-text .l2{font-size:.6rem;color:var(--teal);letter-spacing:.12em;text-transform:uppercase;margin-top:2px;}
nav{display:flex;align-items:center;gap:28px;}
nav a{color:var(--muted);text-decoration:none;font-size:.8rem;letter-spacing:.08em;text-transform:uppercase;transition:color .3s;position:relative;}
nav a::after{content:'';position:absolute;left:0;bottom:-4px;width:0;height:1.5px;background:var(--teal);transition:width .3s;}
nav a:hover{color:var(--white);}nav a:hover::after{width:100%;}
.nav-cta{padding:8px 18px;border:1.5px solid var(--teal);border-radius:30px;color:var(--teal)!important;transition:background .3s,color .3s!important;}
.nav-cta::after{display:none!important;}
.nav-cta:hover{background:var(--teal)!important;color:var(--navy)!important;}
.burger{display:none;flex-direction:column;gap:5px;cursor:pointer;}
.burger span{width:22px;height:2px;background:var(--white);border-radius:2px;}
.hero{position:relative;z-index:2;min-height:100vh;display:flex;align-items:center;padding:115px 5% 75px;gap:55px;}
.hero-left{flex:1;max-width:570px;}
.hero-tag{display:inline-flex;align-items:center;gap:8px;font-size:.7rem;letter-spacing:.16em;text-transform:uppercase;color:var(--teal);margin-bottom:22px;font-weight:500;}
.hero-tag::before{content:'';width:26px;height:1.5px;background:var(--teal);}
.hero h1{font-size:clamp(2.1rem,4.2vw,3.4rem);line-height:1.18;font-weight:700;margin-bottom:20px;}
.hero h1 em{font-style:normal;color:var(--teal);}
.hero-desc{font-size:.94rem;color:var(--muted);line-height:1.8;max-width:430px;margin-bottom:38px;}
.hero-actions{display:flex;gap:13px;flex-wrap:wrap;margin-bottom:48px;}
.btn-p{padding:12px 28px;background:linear-gradient(135deg,var(--teal),var(--teal2));color:var(--navy);border-radius:40px;text-decoration:none;font-weight:500;font-size:.86rem;letter-spacing:.04em;transition:transform .3s,box-shadow .3s;box-shadow:0 0 26px rgba(0,149,217,.33);}
.btn-p:hover{transform:translateY(-3px);box-shadow:0 8px 34px rgba(0,149,217,.48);}
.btn-g{padding:12px 28px;border:1px solid rgba(238,244,255,.18);color:var(--white);border-radius:40px;text-decoration:none;font-size:.86rem;transition:border-color .3s,background .3s;}
.btn-g:hover{border-color:var(--teal);background:rgba(0,149,217,.07);}
.hero-stats{display:flex;gap:38px;padding-top:38px;border-top:1px solid rgba(255,255,255,.07);}
.stat .num{font-family:'Playfair Display',serif;font-size:1.9rem;font-weight:700;}
.stat .num span{color:var(--teal);}
.stat .lbl{font-size:.7rem;color:var(--muted);letter-spacing:.08em;text-transform:uppercase;margin-top:3px;}
.hero-right{flex:1;display:flex;justify-content:center;align-items:center;position:relative;}
.showcase{position:relative;width:390px;height:390px;}
.ring-a{position:absolute;inset:0;border-radius:50%;border:1px solid var(--border);animation:rspin 22s linear infinite;}
.ring-b{position:absolute;inset:42px;border-radius:50%;border:1px dashed rgba(0,201,167,.17);animation:rspin 16s linear infinite reverse;}
.rdot{position:absolute;width:8px;height:8px;background:var(--teal);border-radius:50%;box-shadow:0 0 9px var(--teal);}
@keyframes rspin{to{transform:rotate(360deg);}}
.showcase-center{position:absolute;inset:62px;border-radius:50%;overflow:hidden;background:var(--mid);border:1px solid var(--border);display:flex;align-items:center;justify-content:center;}
.sli{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;padding:26px;opacity:0;transform:scale(.92);transition:opacity .8s,transform .8s;text-align:center;}
.sli.active{opacity:1;transform:scale(1);}
.sli-icon{font-size:2.7rem;margin-bottom:11px;filter:drop-shadow(0 0 11px rgba(0,149,217,.6));}
.sli-name{font-family:'Playfair Display',serif;font-size:.97rem;font-weight:600;margin-bottom:4px;}
.sli-sub{font-size:.7rem;color:var(--muted);letter-spacing:.04em;}
.fbadge{position:absolute;background:rgba(8,18,42,.88);border:1px solid var(--border);backdrop-filter:blur(12px);border-radius:13px;padding:9px 15px;font-size:.7rem;color:var(--white);white-space:nowrap;animation:float 4s ease-in-out infinite;}
.fbadge b{color:var(--teal);font-weight:500;}
.fb1{top:8%;left:-22px;animation-delay:0s;}
.fb2{bottom:13%;left:-28px;animation-delay:1.6s;}
.fb3{top:17%;right:-16px;animation-delay:.9s;}
