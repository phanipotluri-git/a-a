.wcard{background:var(--card);border:1px solid var(--border);border-radius:15px;padding:28px 20px;text-align:center;transition:transform .3s,border-color .3s;}
.wcard:hover{transform:translateY(-5px);border-color:rgba(0,149,217,.42);}
