.wcard h4{font-size:.93rem;margin-bottom:8px;}
.wcard p{font-size:.79rem;color:var(--muted);line-height:1.65;}
#contact{background:var(--deep);}
.contact-wrap{display:flex;gap:52px;align-items:flex-start;flex-wrap:wrap;}
.contact-info{flex:1;min-width:255px;}
.contact-info h3{font-size:1.4rem;margin-bottom:22px;line-height:1.3;}
.cdetail{display:flex;align-items:flex-start;gap:13px;margin-bottom:20px;}
