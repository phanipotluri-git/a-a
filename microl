.cbadge{width:54px;height:54px;border-radius:50%;border:1.5px solid var(--border);background:var(--card);display:flex;align-items:center;justify-content:center;font-size:1.3rem;transition:transform .3s,border-color .3s;}
.citem:hover .cbadge{transform:scale(1.1);border-color:var(--teal);}
.citem span{font-size:.66rem;color:var(--muted);letter-spacing:.09em;text-transform:uppercase;}
