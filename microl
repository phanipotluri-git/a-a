.ft-brand .fl{display:flex;align-items:center;gap:9px;text-decoration:none;margin-bottom:11px;}
.ft-brand .fl .l1{font-family:'Playfair Display',serif;font-size:1.05rem;font-weight:700;color:var(--white);}
.ft-brand p{font-size:.8rem;color:var(--muted);max-width:230px;line-height:1.65;}
.ft-col h5{font-size:.7rem;letter-spacing:.1em;text-transform:uppercase;color:var(--muted);margin-bottom:14px;}
.ft-col a{display:block;color:rgba(238,244,255,.58);text-decoration:none;font-size:.82rem;margin-bottom:8px;transition:color .3s;}
.ft-col a:hover{color:var(--teal);}
.ft-bot{border-top:1px solid rgba(255,255,255,.05);padding-top:20px;display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:10px;}
