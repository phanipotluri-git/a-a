.ticker{position:relative;z-index:2;overflow:hidden;border-top:1px solid var(--border);border-bottom:1px solid var(--border);padding:15px 0;background:var(--deep);}
.ticker-inner{display:flex;gap:52px;animation:tick 24s linear infinite;white-space:nowrap;}
.ticker-inner span{font-size:.72rem;letter-spacing:.12em;text-transform:uppercase;color:var(--muted);display:flex;align-items:center;gap:14px;}
.ticker-inner span::after{content:'◆';color:var(--teal);font-size:.42rem;}
@keyframes tick{from{transform:translateX(0);}to{transform:translateX(-50%);}}
section{position:relative;z-index:2;}
.section{padding:90px 5%;}
.stag{display:inline-flex;align-items:center;gap:8px;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--teal);margin-bottom:13px;font-weight:500;}
.stag::before{content:'';width:22px;height:1.5px;background:var(--teal);}
.section h2{font-size:clamp(1.65rem,2.8vw,2.5rem);line-height:1.25;margin-bottom:13px;}
.section .sub{font-size:.91rem;color:var(--muted);max-width:490px;line-height:1.8;margin-bottom:48px;}
.divider{width:88%;margin:0 auto;height:1px;background:linear-gradient(90deg,transparent,var(--border),transparent);position:relative;z-index:2;}
#about{display:flex;align-items:flex-start;gap:75px;}
.about-l{flex:1;}
.about-r{flex:1;display:grid;grid-template-columns:1fr 1fr;gap:13px;}
.acard{background:var(--card);border:1px solid var(--border);border-radius:15px;padding:22px 18px;transition:transform .3s,border-color .3s;}
.acard:hover{transform:translateY(-5px);border-color:rgba(0,149,217,.4);}
.acard:first-child{grid-column:1/-1;}
.ac-ico{font-size:1.5rem;margin-bottom:11px;}
.acard h4{font-size:.95rem;margin-bottom:7px;}
.acard p{font-size:.8rem;color:var(--muted);line-height:1.65;}
#products{background:var(--deep);}
.cat-tabs{display:flex;flex-wrap:wrap;gap:9px;margin-bottom:38px;}
.tab-btn{padding:8px 18px;border-radius:30px;border:1px solid var(--border);background:transparent;color:var(--muted);font-family:'DM Sans',sans-serif;font-size:.75rem;letter-spacing:.06em;text-transform:uppercase;cursor:pointer;transition:all .3s;}
