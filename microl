<script>
const cv=document.getElementById('bg'),ctx=cv.getContext('2d');
let W,H,pts=[];
function resize(){W=cv.width=innerWidth;H=cv.height=innerHeight;}
resize();window.addEventListener('resize',resize);
class P{constructor(){this.reset(true);}reset(init){this.x=Math.random()*W;this.y=init?Math.random()*H:H+20;this.r=Math.random()*2.4+.7;this.speed=Math.random()*.38+.12;this.drift=(Math.random()-.5)*.27;this.alpha=Math.random()*.18+.04;this.col=Math.random()>.5?'0,149,217':'0,201,167';}step(){this.y-=this.speed;this.x+=this.drift;if(this.y<-15)this.reset();}draw(){ctx.beginPath();ctx.arc(this.x,this.y,this.r,0,Math.PI*2);ctx.fillStyle=`rgba(${this.col},${this.alpha})`;ctx.fill();}}
for(let i=0;i<100;i++)pts.push(new P());
function drawBg(){const g1=ctx.createRadialGradient(W*.18,H*.3,0,W*.18,H*.3,W*.5);g1.addColorStop(0,'rgba(0,65,120,.13)');g1.addColorStop(1,'transparent');ctx.fillStyle=g1;ctx.fillRect(0,0,W,H);const g2=ctx.createRadialGradient(W*.82,H*.65,0,W*.82,H*.65,W*.44);g2.addColorStop(0,'rgba(0,90,70,.11)');g2.addColorStop(1,'transparent');ctx.fillStyle=g2;ctx.fillRect(0,0,W,H);}
function loop(){ctx.clearRect(0,0,W,H);drawBg();pts.forEach(p=>{p.step();p.draw();});requestAnimationFrame(loop);}
loop();
