.pc-cat{font-size:.65rem;letter-spacing:.1em;text-transform:uppercase;color:var(--teal);margin-bottom:12px;font-weight:500;}
.pc-name{font-size:1.18rem;margin-bottom:5px;}
.pc-tagline{font-size:.75rem;color:var(--muted);margin-bottom:12px;font-style:italic;}
.pc-desc{font-size:.81rem;color:var(--muted);line-height:1.68;margin-bottom:16px;}
.pc-feats{list-style:none;display:flex;flex-direction:column;gap:5px;margin-bottom:16px;}
